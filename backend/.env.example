# ─── RAGraph Backend — Environment Variables Template ─────────────────────────
# Copy this to .env and fill in your values for local development.
# For production (Render), set these as environment variables in the dashboard.

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=RAGraph
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-me-to-a-secure-random-string-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── Security ─────────────────────────────────────────────────────────────────
CSRF_ENABLED=false
SECURE_COOKIES=false   # Set to true in production (requires HTTPS)

# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
DEFAULT_LLM=openrouter/free

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=local
EMBEDDING_DIM=384
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Qdrant ───────────────────────────────────────────────────────────────────
# Local dev: run `docker run -p 6333:6333 qdrant/qdrant`
# Production: use Qdrant Cloud (free tier at cloud.qdrant.io)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TEXT_COLLECTION=ragraph_text
QDRANT_IMAGE_COLLECTION=ragraph_images

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: run `docker run -p 6379:6379 redis:alpine`
# Production: use Render managed Redis (auto-linked via render.yaml)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local dev: run `docker run -p 5432:5432 -e POSTGRES_PASSWORD=ragraph_dev postgres:16`
# Production: use Render managed PostgreSQL (auto-linked via render.yaml)
POSTGRES_URL=postgresql://ragraph:ragraph_dev@127.0.0.1:5433/ragraph

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads
# For S3 (production alternative):
# STORAGE_BACKEND=s3
# AWS_BUCKET_NAME=your-bucket
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Cohere (optional reranking) ──────────────────────────────────────────────
COHERE_API_KEY=

# ─── LangSmith (optional observability) ──────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ragraph

# ─── Retrieval v5 Tuning ──────────────────────────────────────────────────────
TOP_K_FINAL=10
RERANK_TOP_N=30
BEAM_WIDTH=5
TREE_SIMILARITY_THRESHOLD_L1=0.20
TREE_SIMILARITY_THRESHOLD_L2=0.15
TREE_SIMILARITY_THRESHOLD_L3=0.10
HYDE_ENABLED=false
DUAL_PATH_FALLBACK_THRESHOLD=0.50
HEADING_SIMILARITY_THRESHOLD=0.65
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=80
MAX_IMAGE_CONTEXT_TOKENS=150
